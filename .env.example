# Environment configurations for myvoiceclone
DB_PATH=/mnt/usb/workspace/myvoiceresearch/myvoiceclone.sqlite
ARTIFACT_ROOT=/mnt/usb/workspace/myvoiceresearch/artifacts
MODELS_DIR=/mnt/usb/workspace/myvoiceresearch/models
MOCK_ADAPTERS=true
LOG_LEVEL=INFO

# Feature Flags
ENABLE_SECURITY_POLICY=false
ENABLE_VEC1_PROBE=false

# Third-party tokens/paths (leave blank for local mock tests)
HUGGINGFACE_TOKEN=
CUDA_VISIBLE_DEVICES=
