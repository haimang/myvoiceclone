# Environment configurations for myvoiceclone
# Data paths are fixed inside the ai-voiceclone container via compose.voiceclone.yaml.
# Host Python/venv execution is not supported by the NF1 runtime contract.
DB_PATH=.data/db/myvoiceclone.sqlite
ARTIFACT_ROOT=.data/artifacts
MODELS_DIR=.data/models
EVIDENCE_ROOT=.data/test-runs
VOICECLONE_PORT=658
MOCK_ADAPTERS=false
LOG_LEVEL=INFO

# Feature Flags
ENABLE_SECURITY_POLICY=false
ENABLE_VEC1_PROBE=false

# Third-party tokens/paths (leave blank for local mock tests)
HUGGINGFACE_TOKEN=
CUDA_VISIBLE_DEVICES=
